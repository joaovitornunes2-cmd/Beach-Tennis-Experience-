.social-project-card::before{content:'';position:absolute;top:-40px;right:-40px;width:160px;height:160px;border:2px solid rgba(204,27,27,0.1);border-radius:50%}
.social-project-card::after{content:'';position:absolute;top:-80px;right:-80px;width:240px;height:240px;border:2px solid rgba(204,27,27,0.06);border-radius:50%}
.social-project-inner{display:flex;flex-direction:column;gap:1.25rem;position:relative;z-index:1}
.social-project-top{display:flex;gap:1.25rem;align-items:flex-start}
.social-icon{flex-shrink:0;width:56px;height:56px;background:#CC1B1B;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#fff;box-shadow:0 4px 20px rgba(204,27,27,0.4)}
.social-label{font-size:.7rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#CC1B1B;margin-bottom:.5rem}
.social-title{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;letter-spacing:1.5px;color:#ffffff;line-height:1.1;margin-bottom:.75rem}
.social-desc{font-size:.9rem;color:rgba(255,255,255,0.72);line-height:1.75;margin-bottom:0}
