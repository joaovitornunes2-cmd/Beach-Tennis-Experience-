<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Beach Tennis Experience – 20 de Junho. Aulas guiadas para iniciantes e Torneio Super 8 para praticantes. Shopping Passeio das Águas, Academia Skyfit, Goiânia.">
<title>Beach Tennis Experience – 20 de Junho</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=Barlow+Condensed:wght@600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --blue:#CC1B1B;
  --blue-light:#E83030;
  --blue-dark:#111111;
  --yellow:#CC1B1B;
  --yellow-light:#E83030;
  --white:#FFFFFF;
  --off-white:#F5F5F5;
  --gray-light:#E8EEF5;
  --gray:#444444;
  --gray-dark:#1a1a1a;
  --sand:#F5F5F5;
  --radius:12px;
  --radius-sm:8px;
}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;color:#222222;background:#fff;overflow-x:hidden}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;background:rgba(10,10,10,0.97);backdrop-filter:blur(8px);padding:0 2rem}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:64px}
.nav-logo{font-family:'Bebas Neue',sans-serif;font-size:1.5rem;color:var(--yellow);letter-spacing:2px;text-decoration:none}
.nav-links{display:flex;gap:2rem;list-style:none}
.nav-links a{color:rgba(255,255,255,0.8);text-decoration:none;font-size:.875rem;font-weight:500;transition:color .2s}
.nav-links a:hover{color:var(--yellow)}
.nav-cta{background:var(--yellow);color:var(--blue-dark);padding:.5rem 1.25rem;border-radius:6px;font-weight:700;text-decoration:none;font-size:.875rem;transition:background .2s}
.nav-cta:hover{background:var(--yellow-light)}
.hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px}
.hamburger span{width:24px;height:2px;background:#fff;transition:all .3s}

/* HERO */
.hero{min-height:100vh;background:url("data:image/jpeg;base64,") center center/cover no-repeat;position:relative;display:flex;align-items:center;overflow:hidden;padding-top:64px}
.hero::before{content:'';position:absolute;inset:0;background:linear-gradient(165deg,rgba(0,0,0,0.88) 0%,rgba(30,0,0,0.75) 50%,rgba(60,10,10,0.55) 100%)}
.hero-deco{position:absolute;right:-100px;top:50%;transform:translateY(-50%);width:600px;height:600px;border:80px solid rgba(204,27,27,0.08);border-radius:50%}
.hero-deco2{position:absolute;right:60px;top:50%;transform:translateY(-50%);width:400px;height:400px;border:2px solid rgba(204,27,27,0.15);border-radius:50%}
.hero-inner{max-width:1200px;margin:0 auto;padding:4rem 2rem;position:relative;z-index:2;width:100%}
.hero-badge{display:inline-block;background:#CC1B1B;color:#fff;font-size:.75rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;padding:.35rem 1rem;border-radius:4px;margin-bottom:1.5rem}
.hero h1{font-family:'Bebas Neue',sans-serif;font-size:clamp(3.5rem,9vw,7rem);color:#fff;line-height:.95;letter-spacing:3px;margin-bottom:1.5rem}
.hero h1 span{color:var(--yellow)}
.hero-sub{font-size:clamp(1rem,2vw,1.2rem);color:rgba(255,255,255,0.8);max-width:560px;line-height:1.6;margin-bottom:2.5rem}
.hero-info{display:flex;flex-wrap:wrap;gap:1rem;margin-bottom:2.5rem}
.info-pill{background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);color:#fff;padding:.5rem 1rem;border-radius:6px;font-size:.875rem;display:flex;align-items:center;gap:.5rem;backdrop-filter:blur(4px)}
.info-pill .icon{font-size:1rem}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap}
.btn-primary{background:var(--yellow);color:var(--blue-dark);padding:.875rem 2rem;border-radius:8px;font-weight:700;text-decoration:none;font-size:1rem;transition:all .2s;display:inline-block;border:none;cursor:pointer}
.btn-primary:hover{background:var(--yellow-light);transform:translateY(-2px)}
.btn-outline{background:transparent;color:#fff;padding:.875rem 2rem;border-radius:8px;font-weight:600;text-decoration:none;font-size:1rem;border:2px solid rgba(255,255,255,0.4);transition:all .2s;display:inline-block}
.btn-outline:hover{border-color:#fff;background:rgba(255,255,255,0.1)}
.hero-scroll{position:absolute;bottom:2rem;left:50%;transform:translateX(-50%);color:rgba(255,255,255,0.4);font-size:.75rem;text-align:center;animation:bounce 2s infinite}
.hero-scroll::after{content:'↓';display:block;font-size:1.2rem;margin-top:.25rem}
@keyframes bounce{0%,100%{transform:translateX(-50%) translateY(0)}50%{transform:translateX(-50%) translateY(6px)}}

/* SECTIONS */
section{padding:5rem 2rem}
.container{max-width:1200px;margin:0 auto}
.section-label{display:inline-block;font-size:.75rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--blue-light);margin-bottom:.75rem}
.section-title{font-family:'Bebas Neue',sans-serif;font-size:clamp(2rem,5vw,3.5rem);color:var(--blue-dark);letter-spacing:2px;margin-bottom:1rem;line-height:1}
.section-title.white{color:#fff}
.section-sub{font-size:1rem;color:var(--gray);max-width:600px;line-height:1.7;margin-bottom:3rem}

/* TABS */
.tabs-section{background:var(--off-white)}
.tab-nav{display:flex;gap:.5rem;margin-bottom:2.5rem;border-bottom:2px solid var(--gray-light);padding-bottom:0}
.tab-btn{background:none;border:none;padding:.875rem 1.5rem;font-size:1rem;font-weight:600;color:#444;cursor:pointer;border-bottom:3px solid transparent;margin-bottom:-2px;transition:all .2s;border-radius:8px 8px 0 0}
.tab-btn.active{color:var(--blue);border-bottom-color:var(--blue)}
.tab-btn:hover:not(.active){color:var(--blue-light)}
.tab-content{display:none}
.tab-content.active{display:block}

/* EXPERIENCE TAB */
.exp-intro{background:#fff;border-radius:var(--radius);padding:2rem;border:1px solid var(--gray-light);margin-bottom:2rem}
.exp-intro h3{font-size:1.5rem;font-weight:700;color:var(--blue-dark);margin-bottom:.75rem}
.exp-intro p{color:#333333;line-height:1.7;margin-bottom:.75rem}
.price-badge{display:inline-flex;align-items:baseline;gap:.25rem;background:var(--blue-dark);color:#fff;padding:.5rem 1.25rem;border-radius:6px;margin-top:.5rem}
.price-badge .amount{font-size:1.5rem;font-weight:700}
.price-badge .label{font-size:.8rem;opacity:.8}
.cert-note{background:var(--sand);border-left:4px solid var(--yellow);padding:.75rem 1rem;border-radius:0 6px 6px 0;margin-top:1rem;font-size:.9rem;color:var(--blue-dark);font-weight:500}

.turmas-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;margin-bottom:2.5rem}
.turma-card{background:#fff;border:2px solid var(--gray-light);border-radius:var(--radius);padding:1.25rem;transition:all .2s;cursor:pointer;position:relative;overflow:hidden}
.turma-card:hover{border-color:var(--blue-light);transform:translateY(-2px)}
.turma-card.full{opacity:.7;cursor:default}
.turma-card.full::after{content:'LOTADA';position:absolute;top:12px;right:12px;background:#e74c3c;color:#fff;font-size:.65rem;font-weight:700;letter-spacing:1px;padding:.2rem .5rem;border-radius:4px}
.turma-card.selected{border-color:var(--blue);background:rgba(26,125,212,.05)}
.turma-num{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--blue);line-height:1}
.turma-time{font-size:.95rem;font-weight:600;color:var(--blue-dark);margin:.25rem 0}
.turma-vagas{font-size:.8rem;color:var(--gray)}
.vagas-bar{height:4px;background:var(--gray-light);border-radius:2px;margin-top:.5rem;overflow:hidden}
.vagas-fill{height:100%;background:var(--blue-light);border-radius:2px;transition:width .5s}
.vagas-fill.warning{background:#f39c12}
.vagas-fill.danger{background:#e74c3c}

/* FORM */
.form-card{background:#fff;border-radius:var(--radius);padding:2rem;border:1px solid var(--gray-light)}
.form-card h3{font-size:1.2rem;font-weight:700;color:var(--blue-dark);margin-bottom:1.5rem}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.form-group{display:flex;flex-direction:column;gap:.4rem}
.form-group.full{grid-column:1/-1}
.form-group label{font-size:.8rem;font-weight:600;color:var(--blue-dark);text-transform:uppercase;letter-spacing:.5px}
.form-group input,.form-group select{border:1.5px solid var(--gray-light);border-radius:6px;padding:.625rem .875rem;font-size:.95rem;font-family:'Inter',sans-serif;color:var(--gray-dark);transition:border-color .2s;background:#fff}
.form-group input:focus,.form-group select:focus{outline:none;border-color:var(--blue-light)}
.radio-group{display:flex;gap:1rem}
.radio-label{display:flex;align-items:center;gap:.4rem;cursor:pointer;font-size:.95rem;color:var(--gray-dark)}
.radio-label input{accent-color:var(--blue)}
.form-submit{width:100%;background:var(--blue);color:#fff;border:none;border-radius:8px;padding:1rem;font-size:1rem;font-weight:700;cursor:pointer;transition:all .2s;margin-top:.5rem;font-family:'Inter',sans-serif}
.form-submit:hover{background:var(--blue-light);transform:translateY(-1px)}
.success-msg{display:none;background:#e8f5e9;border:1px solid #a5d6a7;border-radius:8px;padding:1.5rem;text-align:center;margin-top:1rem}
.success-msg h4{color:#2e7d32;font-size:1.1rem;margin-bottom:.5rem}
.success-msg p{color:#388e3c;font-size:.9rem}
.waitlist-msg{display:none;background:#fff8e1;border:1px solid #ffcc02;border-radius:8px;padding:1rem;margin-bottom:1rem}
.waitlist-msg p{color:#f57f17;font-size:.9rem}

/* SUPER 8 TAB */
.tournament-header{background:linear-gradient(135deg,#111111,#CC1B1B);border-radius:var(--radius);padding:2rem;color:#fff;margin-bottom:2rem;position:relative;overflow:hidden}
.tournament-header::before{content:'8';position:absolute;right:-20px;top:50%;transform:translateY(-50%);font-family:'Bebas Neue',sans-serif;font-size:15rem;color:rgba(255,255,255,0.05);line-height:1}
.tournament-header h3{font-family:'Bebas Neue',sans-serif;font-size:2.5rem;letter-spacing:2px;color:var(--yellow);margin-bottom:.5rem}
.tournament-header p{opacity:.9;line-height:1.6;max-width:500px}
.tournament-header .price-badge{background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.3);margin-top:1rem}
.cats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1rem;margin-bottom:2rem}
.cat-card{background:#fff;border:2px solid var(--gray-light);border-radius:var(--radius);padding:1.5rem;text-align:center}
.cat-icon{font-size:2.5rem;margin-bottom:.75rem}
.cat-title{font-family:'Bebas Neue',sans-serif;font-size:1.75rem;color:var(--blue-dark);letter-spacing:1px}
.cat-vagas{font-size:.85rem;color:var(--gray);margin:.25rem 0}
.cat-count{font-size:1.5rem;font-weight:700;color:var(--blue)}
.premiacao{background:linear-gradient(135deg,#f5f5f5,#ebebeb);border:2px solid var(--yellow);border-radius:var(--radius);padding:1.5rem;margin-bottom:2rem;display:flex;align-items:center;gap:1rem}
.premiacao .trophy{font-size:2.5rem}
.premiacao h4{font-weight:700;color:#111111;margin-bottom:.25rem}
.premiacao p{font-size:.875rem;color:var(--gray)}

/* WHAT TO FIND */
.what-section{background:var(--blue-dark)}
.cards-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.25rem}
.what-card{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);border-radius:var(--radius);padding:1.5rem;transition:all .2s}
.what-card:hover{background:rgba(255,255,255,0.1);transform:translateY(-3px)}
.what-icon{font-size:2rem;margin-bottom:.75rem;display:flex;align-items:center;justify-content:center;color:#fff}
.what-title{font-weight:700;color:#fff;margin-bottom:.4rem}
.what-desc{font-size:.85rem;color:rgba(255,255,255,0.6);line-height:1.5}

/* PROFESSORS */
.prof-grid{display:grid;grid-template-columns:1fr;max-width:600px;margin:0 auto;gap:2rem}
.prof-card{background:#1a1a1a;border-radius:var(--radius);overflow:hidden;border:1px solid rgba(255,255,255,0.1)}
.prof-photo{height:500px;background:linear-gradient(135deg,#CC1B1B 0%,#111111 100%);display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.prof-initials{font-family:'Bebas Neue',sans-serif;font-size:6rem;color:rgba(255,255,255,0.15);position:absolute}
.prof-avatar{width:120px;height:120px;border-radius:50%;background:rgba(255,255,255,0.15);border:3px solid var(--yellow);display:flex;align-items:center;justify-content:center;font-family:'Bebas Neue',sans-serif;font-size:3rem;color:#fff;position:relative;z-index:1}
.prof-info{padding:1.5rem}
.prof-name{font-family:'Bebas Neue',sans-serif;font-size:1.75rem;color:#ffffff;letter-spacing:1px;margin-bottom:.25rem}
.prof-role{font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:var(--blue-light);margin-bottom:.75rem}
.prof-desc{font-size:.9rem;color:rgba(255,255,255,0.75);line-height:1.7}

/* SCHEDULE */
.schedule-section{background:#111111}
.timeline{position:relative;padding-left:2.5rem}
.timeline::before{content:'';position:absolute;left:.75rem;top:0;bottom:0;width:2px;background:linear-gradient(to bottom,#CC1B1B,#E83030)}
.tl-item{position:relative;margin-bottom:1.5rem}
.tl-dot{position:absolute;left:-2.5rem;width:1.5rem;height:1.5rem;background:#CC1B1B;border:3px solid #111111;border-radius:50%;top:0}
.tl-time{font-family:'Barlow Condensed',sans-serif;font-size:.9rem;font-weight:700;color:var(--blue);text-transform:uppercase;letter-spacing:1px;margin-bottom:.1rem}
.tl-event{font-weight:600;color:#ffffff;margin-bottom:.25rem}
.tl-desc{font-size:.875rem;color:rgba(255,255,255,0.70);line-height:1.5}
.tl-all-day{background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);border-radius:var(--radius-sm);padding:1rem 1.25rem;margin-top:1rem}
.tl-all-day h4{font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:#CC1B1B;margin-bottom:.75rem}
.tl-tags{display:flex;flex-wrap:wrap;gap:.5rem}
.tl-tag{background:var(--blue-dark);color:#fff;padding:.3rem .75rem;border-radius:20px;font-size:.8rem;font-weight:500;display:inline-flex;align-items:center;gap:.4rem}

/* PARTNERS PLACEHOLDER */
.partners-section{padding:3rem 2rem;background:#fff;text-align:center}
.partners-title{font-size:.75rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:var(--gray);margin-bottom:1.5rem}
.partners-placeholder{display:flex;justify-content:center;align-items:center;gap:2rem;flex-wrap:wrap}
.partner-box{width:120px;height:60px;border:2px dashed var(--gray-light);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:.7rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:1px}

/* FOOTER */
footer{background:#111111;color:#fff;padding:3rem 2rem 1.5rem}
.footer-inner{max-width:1200px;margin:0 auto}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr;gap:3rem;margin-bottom:2rem;padding-bottom:2rem;border-bottom:1px solid rgba(255,255,255,0.1)}
.footer-brand .logo{font-family:'Bebas Neue',sans-serif;font-size:2rem;color:#CC1B1B;letter-spacing:2px;margin-bottom:.75rem}
.footer-brand p{font-size:.875rem;color:rgba(255,255,255,0.6);line-height:1.6;max-width:280px}
.footer-col h4{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:2px;color:#CC1B1B;margin-bottom:1rem}
.footer-col p,.footer-col a{font-size:.875rem;color:rgba(255,255,255,0.7);line-height:1.8;text-decoration:none;display:block}
.footer-col a:hover{color:var(--yellow)}
.footer-social{display:flex;gap:.75rem;margin-top:1rem}
.social-link{width:36px;height:36px;background:rgba(255,255,255,0.1);border-radius:6px;display:flex;align-items:center;justify-content:center;text-decoration:none;color:rgba(255,255,255,0.7);font-size:.75rem;font-weight:700;transition:all .2s}
.social-link:hover{background:#CC1B1B;color:#fff}
.footer-bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:gap}
.footer-bottom p{font-size:.8rem;color:rgba(255,255,255,0.4)}
.footer-cta{background:#CC1B1B;color:var(--blue-dark);padding:.75rem 1.75rem;border-radius:8px;font-weight:700;text-decoration:none;font-size:.9rem;transition:background .2s}
.footer-cta:hover{background:#E83030}

/* ADMIN PANEL */
.admin-toggle{position:fixed;bottom:2rem;right:2rem;background:#111111;color:#fff;border:none;border-radius:50px;padding:.625rem 1.25rem;font-size:.8rem;font-weight:600;cursor:pointer;z-index:200;box-shadow:0 4px 20px rgba(0,0,0,0.3);display:flex;align-items:center;gap:.5rem;font-family:'Inter',sans-serif}
.admin-panel{display:none;position:fixed;inset:0;z-index:300;background:rgba(0,0,0,0.7);overflow-y:auto}
.admin-panel.open{display:block}
.admin-content{background:#fff;max-width:1000px;margin:2rem auto;border-radius:var(--radius);overflow:hidden}
.admin-header{background:#111111;color:#fff;padding:1.5rem 2rem;display:flex;justify-content:space-between;align-items:center}
.admin-header h2{font-family:'Bebas Neue',sans-serif;font-size:1.75rem;letter-spacing:2px;color:#CC1B1B}
.admin-close{background:none;border:none;color:#fff;font-size:1.5rem;cursor:pointer;line-height:1}
.admin-body{padding:2rem}
.admin-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:2rem}
.stat-box{background:var(--off-white);border-radius:var(--radius-sm);padding:1rem;text-align:center}
.stat-box .num{font-size:2rem;font-weight:700;color:var(--blue)}
.stat-box .lbl{font-size:.75rem;color:var(--gray);font-weight:600;text-transform:uppercase;letter-spacing:1px}
.admin-table-wrap{overflow-x:auto}
table{width:100%;border-collapse:collapse;font-size:.875rem}
th{background:var(--blue-dark);color:#fff;padding:.75rem 1rem;text-align:left;font-size:.75rem;text-transform:uppercase;letter-spacing:1px}
td{padding:.625rem 1rem;border-bottom:1px solid var(--gray-light)}
tr:hover td{background:var(--off-white)}
.badge{display:inline-block;padding:.2rem .6rem;border-radius:4px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px}
.badge-exp{background:#e3f2fd;color:#1565c0}
.badge-tor{background:#f3e5f5;color:#6a1b9a}
.badge-wait{background:#fff3e0;color:#e65100}
.tab-section-titles{display:flex;gap:1rem;margin-bottom:1.5rem}
.admin-tab-btn{background:var(--off-white);border:none;padding:.5rem 1rem;border-radius:6px;font-size:.85rem;font-weight:600;cursor:pointer;color:var(--gray);font-family:'Inter',sans-serif}
.admin-tab-btn.active{background:var(--blue);color:#fff}
.admin-section{display:none}
.admin-section.active{display:block}

/* LEVEL BADGES */
/* PAYMENT */
.payment-section{margin:.5rem 0 1rem;border:1.5px solid var(--gray-light);border-radius:var(--radius-sm);overflow:hidden}
.payment-title{font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:var(--blue-dark);padding:.625rem 1rem;background:var(--off-white);border-bottom:1.5px solid var(--gray-light)}
.payment-options{display:flex;gap:0}
.pay-option{flex:1;padding:.875rem 1rem;cursor:pointer;border:none;background:transparent;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:.6rem;font-size:.9rem;font-weight:500;color:var(--gray);transition:all .2s;border-right:1.5px solid var(--gray-light)}
.pay-option:last-child{border-right:none}
.pay-option:hover{background:var(--off-white)}
.pay-option.active{background:#fff;color:var(--blue-dark)}
.pay-option input[type=radio]{accent-color:var(--blue)}
.pay-detail{padding:1rem;border-top:1.5px solid var(--gray-light);display:none}
.pay-detail.active{display:block}
.pix-box{background:var(--off-white);border-radius:var(--radius-sm);padding:1rem;display:flex;flex-direction:column;gap:.5rem}
.pix-label{font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--blue)}
.pix-key-row{display:flex;align-items:center;gap:.75rem}
.pix-key{font-size:1rem;font-weight:700;color:var(--blue-dark);letter-spacing:.5px;font-family:'Inter',sans-serif}
.pix-copy{background:var(--blue);color:#fff;border:none;border-radius:5px;padding:.35rem .75rem;font-size:.75rem;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;transition:background .2s}
.pix-copy:hover{background:var(--blue-light)}
.pix-note{font-size:.78rem;color:var(--gray);margin-top:.25rem}
.card-box{background:#fff8e1;border:1px solid #ffe082;border-radius:var(--radius-sm);padding:1rem;display:flex;gap:.75rem;align-items:flex-start}
.card-icon{font-size:1.5rem;line-height:1;margin-top:.1rem}
.card-text{font-size:.875rem;color:#5d4037;line-height:1.6}
.card-text strong{color:var(--blue-dark)}
