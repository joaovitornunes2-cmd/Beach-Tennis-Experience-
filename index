.social-link:hover{background:#E83030;transform:translateY(-2px)}
@media(max-width:768px){.social-project-card{padding:1.5rem}.social-icon{width:44px;height:44px}}

.nivel-badge{display:inline-block;padding:.15rem .5rem;border-radius:4px;font-size:.7rem;font-weight:700}
.nivel-iniciante{background:#e8f5e9;color:#2e7d32}
.nivel-intermediario{background:#fff8e1;color:#f57f17}

