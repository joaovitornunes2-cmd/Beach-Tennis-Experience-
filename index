<script>
// DATA STORE (in-memory, simulating DB)
const MAX_TURMA = 6;
const MAX_CAT = 8;

let data = {
  turmas: {1:{inscritos:0},2:{inscritos:1},3:{inscritos:0},4:{inscritos:0}},
  cats: {masc_ini:{inscritos:0},masc_int:{inscritos:0},fem_ini:{inscritos:0},fem_int:{inscritos:0}},
  expList: [],
  torList: [],
  waitList: []
};

// Load from localStorage if available
try {
  const saved = localStorage.getItem('bte_data');
  if(saved) data = JSON.parse(saved);
} catch(e){}

function save(){ try{ localStorage.setItem('bte_data', JSON.stringify(data)); }catch(e){} }

// TURMA CARDS
function renderTurmas(){
  const grid = document.getElementById('turmasGrid');
  const horarios = ['08h00 – 09h00','09h00 – 10h00','10h00 – 11h00','11h00 – 12h00'];
  grid.innerHTML = '';
  for(let i=1;i<=4;i++){
    const t = data.turmas[i];
    const restantes = MAX_TURMA - t.inscritos;
    const pct = (t.inscritos/MAX_TURMA)*100;
    const isFull = restantes <= 0;
    const fillClass = restantes===1?'danger':restantes===2?'warning':'';
    grid.innerHTML += `
      <div class="turma-card ${isFull?'full':''}" id="tc${i}" onclick="selectTurma(${i})">
        <div class="turma-num">T${i}</div>
        <div class="turma-time">⏰ ${horarios[i-1]}</div>
        <div class="turma-vagas">${isFull?'Lista de espera':''+restantes+' vaga'+(restantes!==1?'s':'')+' disponív'+(restantes!==1?'eis':'el')}</div>
        <div class="vagas-bar"><div class="vagas-fill ${fillClass}" style="width:${pct}%"></div></div>
      </div>`;
  }
}

function selectTurma(n){
  document.querySelectorAll('.turma-card').forEach(c=>c.classList.remove('selected'));
  document.getElementById('tc'+n).classList.add('selected');
  document.getElementById('exp_turma').value=n;
  onTurmaSelect();
}

function onTurmaSelect(){
  const v = document.getElementById('exp_turma').value;
  const msg = document.getElementById('waitlistMsg');
  if(!v){msg.style.display='none';return;}
  const t = data.turmas[v];
  msg.style.display = (t.inscritos>=MAX_TURMA)?'block':'none';
}

// CATEGORY CARDS
function renderCats(){
  const grid = document.getElementById('catsGrid');
  const cats = [
    {key:'masc_ini', icon:'male', title:'MASCULINO INICIANTE'},
    {key:'masc_int', icon:'male', title:'MASCULINO INTERMEDIÁRIO'},
    {key:'fem_ini',  icon:'female', title:'FEMININO INICIANTE'},
    {key:'fem_int',  icon:'female', title:'FEMININO INTERMEDIÁRIO'},
  ];
  grid.innerHTML = cats.map(c => {
    const t = data.cats[c.key];
    const restantes = Math.max(0, MAX_CAT - t.inscritos);
    const pct = (t.inscritos/MAX_CAT)*100;
    return `<div class="cat-card">
      <div class="cat-icon" style="display:flex;align-items:center;justify-content:center">${c.icon === "male" ? '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"7\" r=\"4\"/><path d=\"M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2\"/></svg>' : '<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"32\" height=\"32\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"7\" r=\"4\"/><path d=\"M6 21v-2a4 4 0 0 1 4-4h4a4 4 0 0 1 4 4v2\"/></svg>'}</div>
      <div class="cat-title" style="font-size:1.1rem">${c.title}</div>
      <div class="cat-vagas">Vagas disponíveis</div>
      <div class="cat-count" id="cc_${c.key}">${restantes} / ${MAX_CAT}</div>
      <div class="vagas-bar" style="margin-top:.5rem"><div class="vagas-fill" style="width:${pct}%"></div></div>
    </div>`;
  }).join('');
}

function onCatSelect(){
  const v = document.getElementById('tor_cat').value;
  const msg = document.getElementById('waitlistTorMsg');
  if(!v){msg.style.display='none';return;}
  const c = data.cats[v];
  msg.style.display = (c.inscritos>=MAX_CAT)?'block':'none';
}

// SUBMIT EXPERIENCE
function submitExp(){
  const nome = document.getElementById('exp_nome').value.trim();
  const nasc = document.getElementById('exp_nasc').value;
  const tel = document.getElementById('exp_tel').value.trim();
  const email = document.getElementById('exp_email').value.trim();
  const cidade = document.getElementById('exp_cidade').value.trim();
  const turma = document.getElementById('exp_turma').value;
  const praticou = document.querySelector('input[name="exp_praticou"]:checked')?.value||'nao';

  if(!nome||!nasc||!tel||!email||!cidade||!turma){
    alert('Por favor, preencha todos os campos obrigatórios.');return;
  }

  const t = data.turmas[turma];
  const isWait = t.inscritos >= MAX_TURMA;
  const entry = {nome,nasc,tel,email,cidade,turma,praticou,tipo:'exp',isWait,ts:new Date().toISOString()};

  if(isWait){
    data.waitList.push(entry);
  } else {
    t.inscritos++;
    data.expList.push(entry);
  }
  save();
  renderTurmas();
  document.getElementById('formExp').style.display='none';
  document.getElementById('expSuccess').style.display='block';
  document.getElementById('waitlistMsg').style.display='none';
}

// SUBMIT TORNEIO
function submitTor(){
  const nome = document.getElementById('tor_nome').value.trim();
  const tel = document.getElementById('tor_tel').value.trim();
  const email = document.getElementById('tor_email').value.trim();
  const cidade = document.getElementById('tor_cidade').value.trim();
  const cat = document.getElementById('tor_cat').value;

  if(!nome||!tel||!email||!cidade||!cat){
    alert('Por favor, preencha todos os campos obrigatórios.');return;
  }

  const c = data.cats[cat];
  const isWait = c.inscritos >= MAX_CAT;
  const catNames = {'masc_ini':'Super 8 Masculino – Iniciante','masc_int':'Super 8 Masculino – Intermediário','fem_ini':'Super 8 Feminino – Iniciante','fem_int':'Super 8 Feminino – Intermediário'};
  const entry = {nome,tel,email,cidade,cat,nivel:catNames[cat],tipo:'tor',isWait,ts:new Date().toISOString()};

  if(isWait){
    data.waitList.push(entry);
  } else {
    c.inscritos++;
    data.torList.push(entry);
  }
  save();
  renderCats();
  document.getElementById('formTor').style.display='none';
  document.getElementById('torSuccess').style.display='block';
  document.getElementById('waitlistTorMsg').style.display='none';
}

// TABS
function switchTab(tab){
  document.querySelectorAll('.tab-btn').forEach((b,i)=>b.classList.toggle('active',['exp','tor'][i]===tab));
  document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
}

// ADMIN
function toggleAdmin(){
  const p = document.getElementById('adminPanel');
  p.classList.toggle('open');
  if(p.classList.contains('open')) renderAdmin();
}

function switchAdminTab(t){
  document.querySelectorAll('.admin-tab-btn').forEach((b,i)=>b.classList.toggle('active',['exp','tor','wait'][i]===t));
  document.querySelectorAll('.admin-section').forEach(s=>s.classList.remove('active'));
  document.getElementById('admin-'+t).classList.add('active');
}

function renderAdmin(){
  // Stats
  const totalExp = data.expList.length;
  const totalTor = data.torList.length;
  const totalWait = data.waitList.length;
  const totalVagas = Object.values(data.turmas).reduce((a,t)=>a+(MAX_TURMA-t.inscritos),0) + Object.values(data.cats).reduce((a,c)=>a+(MAX_CAT-c.inscritos),0);
  document.getElementById('adminStats').innerHTML = `
    <div class="stat-box"><div class="num">${totalExp}</div><div class="lbl">Inscritos Exp.</div></div>
    <div class="stat-box"><div class="num">${totalTor}</div><div class="lbl">Inscritos Torneio</div></div>
    <div class="stat-box"><div class="num">${totalWait}</div><div class="lbl">Em espera</div></div>
    <div class="stat-box"><div class="num">${totalVagas}</div><div class="lbl">Vagas restantes</div></div>`;

  // Exp table
  const turmaNames = {'1':'T1 08h','2':'T2 09h','3':'T3 10h','4':'T4 11h'};
  document.getElementById('tbodyExp').innerHTML = data.expList.length?
    data.expList.map((e,i)=>`<tr><td>${i+1}</td><td>${e.nome}</td><td><span class="badge badge-exp">${turmaNames[e.turma]||e.turma}</span></td><td>${e.tel}</td><td>${e.email}</td><td>${e.cidade}</td><td>${e.praticou==='sim'?'Sim':'Não'}</td></tr>`).join(''):
    '<tr><td colspan="7" style="text-align:center;color:var(--gray);padding:2rem">Nenhuma inscrição ainda.</td></tr>';

  // Tor table
  const catNames = {masc_ini:'Masc. Iniciante',masc_int:'Masc. Intermediário',fem_ini:'Fem. Iniciante',fem_int:'Fem. Intermediário'};
  document.getElementById('tbodyTor').innerHTML = data.torList.length?
    data.torList.map((e,i)=>`<tr><td>${i+1}</td><td>${e.nome}</td><td>${catNames[e.cat]||e.cat}</td><td><span class="nivel-badge nivel-${e.nivel}">${e.nivel}</span></td><td>${e.tel}</td><td>${e.email}</td><td>${e.cidade}</td></tr>`).join(''):
    '<tr><td colspan="7" style="text-align:center;color:var(--gray);padding:2rem">Nenhuma inscrição ainda.</td></tr>';

  // Wait table
  document.getElementById('tbodyWait').innerHTML = data.waitList.length?
    data.waitList.map((e,i)=>`<tr><td>${i+1}</td><td>${e.nome}</td><td><span class="badge ${e.tipo==='exp'?'badge-exp':'badge-tor'}">${e.tipo==='exp'?'Experiência':'Torneio'}</span></td><td>${e.turma||catNames[e.cat]||'-'}</td><td>${e.tel}</td><td>${e.email}</td></tr>`).join(''):
    '<tr><td colspan="6" style="text-align:center;color:var(--gray);padding:2rem">Nenhuma pessoa em espera.</td></tr>';
}

// NAV MOBILE
function toggleMenu(){
  document.getElementById('navLinks').classList.toggle('open');
}

// PAYMENT TOGGLE
function selectPay(form, method){
  const options = document.querySelectorAll(`input[name="${form}_pay"]`);
  options.forEach(o=>o.checked = o.value===method);
  document.querySelectorAll(`.pay-option`).forEach(btn=>{
    if(btn.querySelector(`input[name="${form}_pay"]`))
      btn.classList.toggle('active', btn.querySelector('input').value===method);
  });
  document.getElementById(`${form}_pay_pix`).classList.toggle('active', method==='pix');
  document.getElementById(`${form}_pay_card`).classList.toggle('active', method==='card');
}

function copyPix(elId, btn){
  const raw = document.getElementById(elId).textContent.replace(/\D/g,'');
  navigator.clipboard.writeText(raw).then(()=>{
    btn.textContent='✅ Copiado!';
    setTimeout(()=>btn.textContent='Copiar',2000);
  }).catch(()=>{
    btn.textContent='Copiar manualmente';
  });
}

// INIT
renderTurmas();
renderCats();

// SCROLL ANIMATIONS
const observer = new IntersectionObserver((entries)=>{
  entries.forEach(e=>{if(e.isIntersecting)e.target.style.opacity='1'});
},{threshold:.1});
document.querySelectorAll('.what-card,.prof-card,.tl-item,.turma-card').forEach(el=>{
  el.style.opacity='0';el.style.transition='opacity .5s, transform .5s';
  observer.observe(el);
});
</script>
